{
  "$schema": "https://opencode.ai",
  "mcp": {
    "nixos": {
      "type": "local",
      "command": ["docker", "run", "--rm", "-i", "ghcr.io/utensils/mcp-nixos"]
    },
    "open-pencil": {
      "type": "local",
      "command": ["/run/current-system/sw/bin/bun", "x", "@open-pencil/mcp"]
    }
  },
  "lsp": {
    "nixd": {
      "command": ["nixd"]
    }
  }
}
