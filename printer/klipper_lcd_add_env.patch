From: SweetCapitan <danil.duhanin@yandex.ru>
Date: Sun, 7 Sep 2025 03:48:39 +0300
Subject: [PATCH 5/5] Add env variables and fix SHORT_BUILD_VERSION for
 Moonraker 0.8

---
 lcd.py | 16 ++++++++++++----
 1 file changed, 12 insertions(+), 4 deletions(-)

diff --git a/lcd.py b/lcd.py
index ca31f69..ed41053 100644
--- a/lcd.py
+++ b/lcd.py
@@ -212,21 +212,29 @@ class LCD:
         self.write("information.sversion.txt=\"%s\"" % fw)        
 
     def write(self, data, eol=True, lf=False):
+    # Преобразуем всё в байты напрямую, отбрасывая символы > 255
         dat = bytearray()
-        if type(data) == str:
-            dat.extend(map(ord, data))
+        if isinstance(data, str):
+            for c in data:
+                if ord(c) < 256:
+                    dat.append(ord(c))
+                    # символы >255 просто игнорируем
         else:
             dat.extend(data)
 
         if lf:
             dat.extend(dat[-1:])
             dat.extend(dat[-1:])
-            dat[len(dat)-2] = 10 #'\r'
-            dat[len(dat)-3] = 13 #'\n'
+            dat[-2] = 10  # '\n'
+            dat[-3] = 13  # '\r'
+
         self.ser.write(dat)
+
         if eol:
             self.ser.write(bytearray([0xFF, 0xFF, 0xFF]))
 
+
+
     def clear_thumbnail(self):
         self.write("printpause.cp0.close()")
         self.write("printpause.cp0.aph=0")
